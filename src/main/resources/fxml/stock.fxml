<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21.0.0"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="siks.controllers.StockController"
            style="-fx-background-color: #eef2f7;">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox spacing="15"
              prefWidth="220"
              style="-fx-padding: 15;
                     -fx-background-color: linear-gradient(to bottom, #1f2a44, #2c3e50);" alignment="CENTER">

            <!-- TITLE -->
            <Label text="Stock Control"
                   style="-fx-text-fill: white;
                          -fx-font-size: 18px;
                          -fx-font-weight: bold;"/>

            <!-- ITEM ID -->
            <VBox spacing="5">
                <Label text="Item ID" style="-fx-text-fill:#cfd8dc;"/>
                <TextField fx:id="txtItemId"
                           editable="false"
                           prefWidth="150"
                           style="-fx-background-radius:6;"/>
            </VBox>

            <!-- ITEM NAME -->
            <VBox spacing="5">
                <Label text="Item Name" style="-fx-text-fill:#cfd8dc;"/>
                <TextField fx:id="txtItemName"
                           editable="false"
                           prefWidth="150"
                           style="-fx-background-radius:6;"/>
            </VBox>

            <!-- CARTONS -->
            <VBox spacing="5">
                <Label text="Cartons" style="-fx-text-fill:#cfd8dc;"/>
                <TextField fx:id="txtCartons"
                           prefWidth="150"
                           style="-fx-background-radius:6;"/>
            </VBox>

            <!-- PIECES -->
            <VBox spacing="5">
                <Label text="Pieces" style="-fx-text-fill:#cfd8dc;"/>
                <TextField fx:id="txtPieces"
                           prefWidth="150"
                           style="-fx-background-radius:6;"/>
            </VBox>

            <!-- BUTTON -->
            <Button fx:id="btnSave"
                    text="Update Stock"
                    prefWidth="150"
                    style="-fx-background-color:#0984e3;
                           -fx-text-fill:white;
                           -fx-font-weight:bold;"/>

            <Separator/>

            <!-- SEARCH -->
            <VBox spacing="5">
                <Label text="Search" style="-fx-text-fill:#cfd8dc;"/>
                <TextField fx:id="txtSearch"
                           prefWidth="150"
                           promptText="Search item..."
                           style="-fx-background-radius:6;"/>
            </VBox>

        </VBox>
    </left>

    <!-- ================= CENTER TABLE ================= -->
    <center>
        <VBox style="-fx-padding: 10;">

            <TableView fx:id="tblStock"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white;
                              -fx-border-color: #d0d7de;
                              -fx-background-radius: 8;">

                <columns>

                    <TableColumn fx:id="colItemId" text="Item ID" prefWidth="100"/>
                    <TableColumn fx:id="colItemName" text="Item Name" prefWidth="220"/>
                    <TableColumn fx:id="colCartons" text="Cartons" prefWidth="90"/>
                    <TableColumn fx:id="colPieces" text="Pieces" prefWidth="90"/>
                    <TableColumn fx:id="colLastEdited" text="Last Edited" prefWidth="160"/>
                    <TableColumn fx:id="colChangeType" text="Change Type" prefWidth="120"/>

                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>