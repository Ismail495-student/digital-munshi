<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="siks.controllers.LoginController"
            prefWidth="500" prefHeight="350"
             stylesheets="@../css/style.css" styleClass="login-pane"
            >

    <!-- ======= Main Container ======= -->
    <VBox alignment="CENTER" spacing="20" prefWidth="400" prefHeight="300"
          layoutX="50" layoutY="25">

        <!-- Title -->
        <Label text="🛍 WELCOME TO ABDUL JABBAR &amp; SONS"
               style="-fx-font-size: 20px; -fx-font-weight: bold; "/>

        <!-- Username -->
        <VBox alignment="CENTER_LEFT" spacing="5">
            <Label text="Username:" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtUsername"
                       promptText="Enter username"
                       prefWidth="250"
                       style="-fx-background-radius: 8; -fx-padding: 6;"/>
        </VBox>

        <!-- Password -->
        <VBox alignment="CENTER_LEFT" spacing="5">
            <Label text="Password:" style="-fx-font-weight: bold;"/>
            <PasswordField fx:id="txtPassword"
                           promptText="Enter password"
                           prefWidth="250"
                           style="-fx-background-radius: 8; -fx-padding: 6;"/>
        </VBox>

        <!-- Buttons -->
        <HBox alignment="CENTER" spacing="20" style="-fx-padding: 10;">
            <Button fx:id="btnLogin" text="Login"
                    prefWidth="100"
                    style="-fx-background-color: #0984e3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>
            <Button fx:id="btnCancel" text="Cancel"
                    prefWidth="100"
                    style="-fx-background-color: #d63031; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10;"/>
        </HBox>

        <!-- Footer -->
        <Label text="© 2026 Developed by SHEIKH ISMAEEL "
               style="-fx-font-size: 11px; -fx-text-fill: #636e72;"/>

    </VBox>
</AnchorPane>
