<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="siks.controllers.UserManagementController"
            style="-fx-background-color:#f4f6f8;">

    <!-- ================= TOP ================= -->
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-background-color:white; -fx-padding:15; -fx-border-color:#dddddd;">

            <Label text="User Management"
                   style="-fx-font-size:22px; -fx-font-weight:bold; -fx-text-fill:#2c3e50;" />

            <Pane HBox.hgrow="ALWAYS"/>

            <Label fx:id="lblStatus"
                   style="-fx-font-size:14px; -fx-font-weight:bold;" />
        </HBox>
    </top>

    <!-- ================= LEFT FORM ================= -->
    <left>
        <VBox spacing="12"
              prefWidth="250"
              style="-fx-background-color:white; -fx-padding:18; -fx-border-color:#dddddd;">

            <Label text="Create / Edit User"
                   style="-fx-font-size:18px; -fx-font-weight:bold;"/>

            <Label text="Username"/>
            <TextField fx:id="txtUsername" promptText="Enter username"/>

            <Label text="Password"/>
            <PasswordField fx:id="txtPassword" promptText="Enter password"/>

            <Label text="Role"/>
            <ComboBox fx:id="cmbRole" prefWidth="300"/>

            <Separator/>

            <Label text="Permissions"
                   style="-fx-font-size:16px; -fx-font-weight:bold;"/>

            <ScrollPane fitToWidth="true" prefHeight="350">
                <VBox spacing="8">

                    <CheckBox fx:id="chkCustomer" text="Customer"/>
                    <CheckBox fx:id="chkSupplier" text="Supplier"/>
                    <CheckBox fx:id="chkItem" text="Item"/>
                    <CheckBox fx:id="chkVoucher" text="Voucher"/>
                    <CheckBox fx:id="chkInvoice" text="Invoice"/>

                    <CheckBox fx:id="chkCustomerReport" text="Customer Report"/>
                    <CheckBox fx:id="chkSupplierReport" text="Supplier Report"/>
                    <CheckBox fx:id="chkStockReport" text="Stock Report"/>

                    <CheckBox fx:id="chkOverview" text="Overview"/>
                    <CheckBox fx:id="chkAnalytics" text="Analytics"/>
                    <CheckBox fx:id="chkSettings" text="Settings"/>

                    <CheckBox fx:id="chkSalesInvoice" text="Sales Invoice"/>
                    <CheckBox fx:id="chkPurchaseInvoice" text="Purchase Invoice"/>
                    <CheckBox fx:id="chkOpenInvoice" text="Open Invoice"/>

                </VBox>
            </ScrollPane>

            <Separator/>

            <HBox spacing="8">

                <Button fx:id="btnAddUser"
                        text="Add"
                        prefWidth="75"
                        style="-fx-background-color:#27ae60; -fx-text-fill:white;"/>

                <Button fx:id="btnUpdateUser"
                        text="Update"
                        prefWidth="75"
                        style="-fx-background-color:#2980b9; -fx-text-fill:white;"/>

                <Button fx:id="btnDeleteUser"
                        text="Delete"
                        prefWidth="75"
                        style="-fx-background-color:#e74c3c; -fx-text-fill:white;"/>

                <Button fx:id="btnClear"
                        text="Clear"
                        prefWidth="75"
                        style="-fx-background-color:#7f8c8d; -fx-text-fill:white;"/>

            </HBox>

        </VBox>
    </left>

    <!-- ================= CENTER TABLE ================= -->
    <center>

        <VBox spacing="10" >

            <Label text="Users List"
                   style="-fx-font-size:18px; -fx-font-weight:bold;"/>

            <TableView fx:id="tblUsers" VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="colUsername"
                                 text="Username"
                                 prefWidth="170"/>

                    <TableColumn fx:id="colRole"
                                 text="Role"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colPermissions"
                                 text="Permissions"
                                 prefWidth="550"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>