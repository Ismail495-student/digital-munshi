<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="siks.controllers.ItemController"
            style="-fx-background-color:#f5f6fa;">

    <!-- ================= TOP ================= -->
    <top>
        <HBox spacing="10"
              style="-fx-padding:10; -fx-background-color:#2c3e50;">

            <Label text="ITEM MANAGEMENT"
                   style="-fx-text-fill:white; -fx-font-size:16; -fx-font-weight:bold;"/>

            <Region HBox.hgrow="ALWAYS"/>


        </HBox>
    </top>

    <!-- ================= CENTER ================= -->
    <center>
        <HBox spacing="12" style="-fx-padding:12;">

            <!-- ========== LEFT FORM ========== -->
            <VBox spacing="10"
                  prefWidth="400"
                  style="-fx-background-color:#ecf0f1;
                         -fx-padding:15;
                         -fx-background-radius:10;">



                <VBox spacing="5">

                    <Label text="Item Name"/>
                    <TextField fx:id="txtName"/>

                    <Label text="Print Name"/>
                    <TextField fx:id="txtPrintName"/>

                    <Label text="Purchase Rate"/>
                    <TextField fx:id="txtPurchaseRate"/>

                    <Label text="Retail Rate"/>
                    <TextField fx:id="txtRetailRate"/>

                    <Label text="Wholesale Rate"/>
                    <TextField fx:id="txtWholesaleRate"/>

                    <Label text="Pieces / Carton"/>
                    <TextField fx:id="txtPiecesPerCarton"/>

                    <Label text="Category"/>
                    <ComboBox fx:id="cbCategory"/>

                    <!-- ✅ FIXED: Company is INPUT FIELD -->
                    <Label text="Company"/>
                    <TextField fx:id="txtCompany"/>

                </VBox>

                <!-- BUTTONS -->
                <VBox spacing="8" style="-fx-padding:10 0 0 0;">

                    <Button fx:id="btnAdd" text="Add"
                            maxWidth="Infinity"
                            style="-fx-background-color:#0984e3; -fx-text-fill:white;"/>

                    <Button fx:id="btnUpdate" text="Update"
                            maxWidth="Infinity"
                            style="-fx-background-color:#00b894; -fx-text-fill:white;"/>

                    <Button fx:id="btnDelete" text="Delete"
                            maxWidth="Infinity"
                            style="-fx-background-color:#d63031; -fx-text-fill:white;"/>

                    <Button fx:id="btnClear" text="Clear"
                            maxWidth="Infinity"
                            style="-fx-background-color:#636e72; -fx-text-fill:white;"/>

                </VBox>

            </VBox>

            <!-- ========== RIGHT TABLE ========== -->
            <VBox spacing="10" HBox.hgrow="ALWAYS">

                <HBox spacing="10">
                    <TextField fx:id="txtSearch"
                               promptText="Search item or company..."
                               HBox.hgrow="ALWAYS"/>

                    <ComboBox fx:id="cbCategoryFilter"
                              prefWidth="160"/>
                </HBox>

                <TableView fx:id="tblItems" VBox.vgrow="ALWAYS">

                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="colName" text="Name" prefWidth="140"/>
                        <TableColumn fx:id="colPrintName" text="Print Name" prefWidth="140"/>
                        <TableColumn fx:id="colPurchaseRate" text="Purchase" prefWidth="100"/>
                        <TableColumn fx:id="colRetailRate" text="Retail" prefWidth="100"/>
                        <TableColumn fx:id="colWholesaleRate" text="Wholesale" prefWidth="120"/>
                        <TableColumn fx:id="colPiecesPerCarton" text="P/Carton" prefWidth="110"/>
                        <TableColumn fx:id="colCategory" text="Category" prefWidth="120"/>
                        <TableColumn fx:id="colCompany" text="Company" prefWidth="140"/>
                        <TableColumn fx:id="colStockQuantity" text="Stock" prefWidth="100"/>
                    </columns>

                </TableView>

            </VBox>

        </HBox>
    </center>

</BorderPane>